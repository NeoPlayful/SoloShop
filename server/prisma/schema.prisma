generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── 管理员 ───
model Admin {
  id          Int       @id @default(autoincrement())
  username    String    @unique
  password    String    // bcrypt 加密
  nickname    String?
  isActive    Boolean   @default(true)
  isSuperAdmin Boolean  @default(false)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  operationLogs OperationLog[]
}

// ─── 商品分类 ───
model Category {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isVisible   Boolean   @default(true)   // 前台是否显示
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
}

// ─── 商品 ───
model Product {
  id              Int       @id @default(autoincrement())
  name            String
  slug            String    @unique
  categoryId      Int
  description     String?   // 商品详情（富文本 HTML）
  coverImage      String?   // 封面图 URL
  price           Decimal   @db.Decimal(10, 2)
  originalPrice   Decimal?  @db.Decimal(10, 2)  // 划线价
  costPrice       Decimal?  @db.Decimal(10, 2)  // 成本价
  salesCount      Int       @default(0)          // 销量（冗余）
  deliveryType    String    @default("auto_card") // auto_card / text / manual
  deliveryContent String?   // 固定文本发货内容（text 类型时使用）
  minQuantity     Int       @default(1)
  maxQuantity     Int       @default(1)
  status          String    @default("draft")    // draft / active / inactive / sold_out
  sortOrder       Int       @default(0)
  isHidden        Boolean   @default(false)      // 隐藏后前台不可见
  purchaseNotes   String?   // 购买须知
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? // 软删除

  category    Category @relation(fields: [categoryId], references: [id])
  cards       Card[]
  orders      Order[]

  @@index([categoryId])
  @@index([status])
  @@index([slug])
}

// ─── 卡密库存 ───
model Card {
  id        Int       @id @default(autoincrement())
  productId Int
  content   String    // 卡密内容
  status    String    @default("available") // available / locked / sold / disabled / expired
  batchNo   String?   // 批次号
  orderId   Int?      // 锁定或售出时关联订单
  lockedAt  DateTime? // 锁定时间（用于超时释放判断）
  soldAt    DateTime?
  createdAt DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])

  @@index([productId, status])
  @@index([orderId])
  @@index([batchNo])
  @@index([status])
}

// ─── 订单 ───
model Order {
  id              Int       @id @default(autoincrement())
  orderNo         String    @unique
  productId       Int
  productSnapshot Json      // 下单时商品快照（名称、价格等）
  quantity        Int
  totalAmount     Decimal   @db.Decimal(10, 2)
  buyerEmail      String?   // 买家邮箱（订单查询用）
  buyerContact    String?   // 买家联系方式
  buyerIp         String?
  userAgent       String?
  orderStatus     String    @default("pending")  // pending / completed / cancelled / closed
  paymentStatus   String    @default("unpaid")   // unpaid / paid / failed / refunded
  deliveryStatus  String    @default("pending")  // pending / delivering / delivered / failed
  paidAt          DateTime?
  deliveredAt     DateTime?
  note            String?   // 后台备注
  createdAt       DateTime  @default(now())
  expiredAt       DateTime? // 订单过期时间

  product    Product        @relation(fields: [productId], references: [id])
  cards      Card[]
  payments   Payment[]
  deliveries Delivery[]

  @@index([orderNo])
  @@index([productId])
  @@index([paymentStatus])
  @@index([createdAt])
}

// ─── 支付记录 ───
model Payment {
  id             Int       @id @default(autoincrement())
  orderId        Int
  channel        String    // 支付渠道编码 yipay / stripe
  tradeNo        String?   // 平台订单号
  channelOrderNo String?   // 支付渠道订单号
  amount         Decimal   @db.Decimal(10, 2)
  paidAmount     Decimal?  @db.Decimal(10, 2)  // 实际支付金额
  status         String    @default("pending")  // pending / success / failed
  rawData        Json?     // 回调原始数据
  isActive       Boolean   @default(true)       // 当前生效的支付记录
  createdAt      DateTime  @default(now())
  paidAt         DateTime?

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([tradeNo])
}

// ─── 发货记录 ───
model Delivery {
  id          Int       @id @default(autoincrement())
  orderId     Int
  type        String    // card / text / manual
  content     String?   // 发货内容（卡密原文 / 固定文本 / 人工填写）
  status      String    @default("pending")  // pending / delivered / failed
  failReason  String?
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

// ─── 支付渠道配置 ───
model PaymentChannel {
  id        Int      @id @default(autoincrement())
  code      String   @unique // yipay / stripe
  name      String
  config    Json     // 渠道配置（密钥、URL等），前端返回时脱敏
  isEnabled Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── 操作日志 ───
model OperationLog {
  id         Int      @id @default(autoincrement())
  adminId    Int?
  action     String   // product.create / order.mark-paid 等
  targetType String   // product / order / card 等
  targetId   Int?
  detail     Json?
  ip         String?
  createdAt  DateTime @default(now())

  admin Admin? @relation(fields: [adminId], references: [id])

  @@index([targetType, targetId])
  @@index([createdAt])
}

// ─── 系统设置 ───
model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}
